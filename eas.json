{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://getcamino.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://getcamino.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://getcamino.app"
      }
    },
    "e2e-test": {
      "withoutCredentials": true,
      "environment": "preview",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://camino--staging.expo.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6786412055"
      }
    }
  }
}