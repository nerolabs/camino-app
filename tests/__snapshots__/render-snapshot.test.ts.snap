"<!doctype html>
<html><head><meta charset="utf-8"><title>Get Camino — your road to Spain</title>
<style>@page { margin: 18mm 15mm; } body { margin: 0; }</style></head>
<body style="background:#FBFAF7;font-family:Georgia,'Times New Roman',serif;color:#15243B;">
<!-- Container padding is the margin fallback: iOS's HTML→PDF renderer ignores @page
     (build-25 QA finding: zero print margins), so the page must carry its own. -->
<div style="max-width:720px;margin:0 auto;padding:28px 24px;font-family:Helvetica,Arial,sans-serif;">

  <div style="display:flex;justify-content:space-between;align-items:baseline;border-bottom:2px solid #15243B;padding-bottom:10px;">
    <div style="font-family:Georgia,serif;font-size:22px;font-weight:600;">Get Camino <span style="font-size:12px;color:#4A5A70;font-style:italic;">— your road to Spain</span></div>
    <div style="font-size:10px;color:#4A5A70;">Generated 3 Jul 2026</div>
  </div>

  <div style="display:flex;gap:18px;margin-top:12px;font-size:11px;color:#4A5A70;">
    <span><b style="color:#15243B;font-size:14px;">4</b> steps</span>
    <span><b style="color:#2B5AA3;font-size:14px;">4</b> required</span>
    <span><b style="color:#5E7355;font-size:14px;">1</b> done</span>
    <span><b style="color:#C0392B;font-size:14px;">1</b> overdue</span>
  </div>

  <div style="page-break-inside:avoid;background:#FFFFFF;border:2px solid #BD8318;border-radius:10px;padding:14px 16px;margin:18px 0 6px;">
      <div style="font-size:9px;letter-spacing:2px;color:#BD8318;font-weight:700;margin-bottom:6px;">YOUR NEXT STEP</div>
      <div style="font-size:15px;line-height:20px;color:#15243B;font-weight:600;">Title of hero-step</div>
      <div style="font-size:11px;margin-top:4px;color:#15243B;font-weight:600;">Due 13 Jul 2026 (estimated)</div>
    </div>

  
  <div style="margin-top:20px;">
