{
  "name": "camino-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "deploy:staging": "bash scripts/deploy.sh staging",
    "deploy:production": "bash scripts/deploy.sh production",
    "ota:production": "npm run --silent audit && npm run --silent test && EXPO_PUBLIC_API_URL=https://getcamino.app npx eas-cli update --channel production --environment production --auto",
    "audit": "npx tsx scripts/audit-catalog.ts",
    "audit:matrix": "npx tsx scripts/audit-matrix.ts",
    "freshness": "npx tsx scripts/freshness-check.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "RUN_API=1 vitest run tests/api.contract.test.ts",
    "test:e2e": "playwright test",
    "docs:catalog": "npx tsx scripts/gen-catalog-docs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo/app-integrity": "^56.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/browser": "^10.63.0",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.110.0",
    "expo": "~56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-build-properties": "~56.0.20",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.20",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-updates": "~56.0.20",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.4",
    "posthog-js": "^1.396.4",
    "posthog-react-native": "^4.54.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.2",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "private": true
}
