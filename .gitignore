# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# macOS/editor accidental duplicates ("File 2.ext" — note the space before the number)
* [0-9].ts
* [0-9].tsx

# test artifacts
playwright-report/
test-results/

# Playwright captured auth state (contains a live staging session)
tests-e2e/.auth/
docs/store-assets/clean/
